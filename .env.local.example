# ─────────────────────────────────────────────────────────────────────────────
# Condomínio Bela Vista — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — ele contém segredos.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Desenvolvimento local (SQLite):
# DATABASE_URL="file:./dev.db"

# Produção (MySQL — substitua os valores):
DATABASE_URL="mysql://USUARIO:SENHA@HOST:3306/bela_vista"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-segredo-aqui-minimo-32-caracteres"

# URL pública do servidor (obrigatório em produção)
# NEXTAUTH_URL="https://seudominio.com"

# ── OAuth Google (opcional) ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── OAuth GitHub (opcional) ───────────────────────────────────────────────────
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── OAuth Microsoft / Azure AD (opcional) ─────────────────────────────────────
# https://portal.azure.com → Registros de aplicativos
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"
