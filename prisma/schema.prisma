generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ─── Provider ──────────────────────────────────────────────────────────────
// Desenvolvimento local:  provider = "sqlite"
// Produção (MySQL/Linux): provider = "mysql"
//
// Para migrar para MySQL:
//   1. Troque para provider = "mysql"
//   2. Atualize DATABASE_URL em .env.local para mysql://user:pass@host:3306/db
//   3. Execute: npm run db:generate && npm run db:deploy
// ───────────────────────────────────────────────────────────────────────────
datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  role          String          @default("PENDING")
  password      String?
  // JSON: { theme, palette, sidebarLogo } — personalização individual
  preferences   String?
  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  imports       ImportHistory[]
  createdAt     DateTime        @default(now())
}

// Configurações globais do sistema (ex.: favicon definido pelo administrador)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  type         String
  color        String        @default("#6366f1")
  icon         String        @default("tag")
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id          String         @id @default(cuid())
  userId      String
  type        String
  description String
  amount      Float
  date        DateTime
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  source      String         @default("MANUAL")
  importId    String?
  import      ImportHistory? @relation(fields: [importId], references: [id])
  notes       String?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model AccountStatement {
  id            String    @id @default(cuid())
  month         String    @unique // "2026-06"
  saldoEmConta  Float     @default(0)
  totalReceitas Float     @default(0)
  totalDespesas Float     @default(0)
  resultado     Float     @default(0)
  status        String    @default("ABERTA")
  notes         String?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Investimentos ───────────────────────────────────────────────────────────
// Extrato DTVM = fotografia (snapshot) da posição na data DTASOF + fluxos.
// Linhas "RENDIMENTO/I.R./I.O.F. ATÉ ESTA DATA" são acumuladas na data do
// extrato e NUNCA se somam entre importações; APLICAÇÃO/RESGATE são fluxos.
model InvestmentStatement {
  id          String               @id @default(cuid())
  date        DateTime             @unique // DTASOF do extrato
  // MOVIMENTACAO (acumulados do extrato) | POSICAO (carteira oficial do banco)
  kind        String               @default("MOVIMENTACAO")
  totalValue  Float // POSICAO: bruto oficial; MOVIMENTACAO: saldo informativo do arquivo
  rendimento  Float                @default(0) // Σ rendimentos "até esta data"
  irPrevisto  Float                @default(0) // Σ I.R. previsto p/ resgate total
  iofPrevisto Float                @default(0) // Σ I.O.F. previsto
  periodStart DateTime?
  periodEnd   DateTime?
  filename    String
  fileHash    String?
  userId      String
  movements   InvestmentMovement[]
  createdAt   DateTime             @default(now())
}

model InvestmentMovement {
  id          String               @id @default(cuid())
  date        DateTime
  // APLICACAO | RESGATE | RENDIMENTO | IR_PREVISTO | IOF_PREVISTO | OUTRO
  type        String
  description String
  amount      Float // sempre positivo; o sinal vem do type
  fitid       String?
  // true = linha "até esta data" (acumulado do snapshot, não é fluxo)
  snapshot    Boolean              @default(false)
  statementId String?
  statement   InvestmentStatement? @relation(fields: [statementId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime             @default(now())
}

model ImportHistory {
  id           String        @id @default(cuid())
  userId       String
  filename     String
  fileType     String
  fileHash     String?
  recordCount  Int
  status       String        @default("SUCCESS")
  errorMessage String?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}
